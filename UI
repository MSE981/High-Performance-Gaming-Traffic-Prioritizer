from flask import Flask, jsonify, request, render_template_string
import time

app = Flask(__name__)

STATE = {
    "running": False,
    "mode": "balanced",
    "game_target": "192.168.1.50",
    "iface": "eth0",
    "last_action": "none",
    "updated": time.strftime("%H:%M:%S")
}

HTML = """
<!doctype html>
<html lang="zh">
<head>
  <meta charset="utf-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1"/>
  <title>GamingTrafficPrioritizer 控制台</title>
  <style>
    body { font-family: system-ui, Arial; background:#0b0f17; color:#e6edf3; margin:0; }
    .container { max-width: 920px; margin: 24px auto; padding: 0 16px; }
    h1 { font-size: 26px; margin: 8px 0 16px; }
    .card { background:#121a26; border:1px solid #223046; border-radius:14px; padding:16px; margin:14px 0; }
    .grid { display:grid; grid-template-columns: 1fr 1fr; gap:10px; margin:10px 0; }
    button { padding:10px 14px; border-radius:10px; border:1px solid #2a3b57; background:#182236; color:#e6edf3; cursor:pointer; margin-right:8px; }
    button.primary { background:#1f6feb; border-color:#1f6feb; }
    button.danger { background:#da3633; border-color:#da3633; }
    input, select { width:100%; padding:10px; border-radius:10px; border:1px solid #2a3b57; background:#0b1220; color:#e6edf3; margin:8px 0 12px; }
    .pill { display:inline-block; padding:4px 10px; border:1px solid #2a3b57; border-radius:999px; margin-left:8px; font-size:12px; }
    pre { background:#0b1220; padding:12px; border-radius:10px; border:1px solid #2a3b57; overflow:auto; }
  </style>
</head>
<body>
  <div class="container">
    <h1>🎮 GamingTrafficPrioritizer 控制台 <span class="pill" id="updated">--</span></h1>

    <div class="card">
      <h2>状态总览</h2>
      <div class="grid">
        <div>运行状态：<b id="running">-</b></div>
        <div>接口：<b id="iface">-</b></div>
        <div>模式：<b id="mode">-</b></div>
        <div>游戏目标：<b id="target">-</b></div>
        <div>最近动作：<b id="last_action">-</b></div>
      </div>
      <button onclick="refresh()">刷新</button>
    </div>

    <div class="card">
      <h2>一键控制</h2>
      <button class="primary" onclick="doAction('start')">Start</button>
      <button class="danger" onclick="doAction('stop')">Stop</button>
      <button onclick="doAction('restart')">Restart</button>
    </div>

    <div class="card">
      <h2>配置</h2>
      <label>模式：</label>
      <select id="modeSelect">
        <option value="gaming">Gaming Priority</option>
        <option value="balanced">Balanced</option>
        <option value="download">Download Priority</option>
      </select>

      <label>游戏设备 IP/MAC：</label>
      <input id="targetInput" placeholder="例如 192.168.1.50 或 AA:BB:CC:DD:EE:FF"/>

      <button onclick="saveConfig()">保存配置</button>
    </div>

    <div class="card">
      <h2>日志（示例）</h2>
      <pre id="logBox">[INFO] UI server started…</pre>
    </div>
  </div>

<script>
async function refresh(){
  const r = await fetch("/api/state");
  const s = await r.json();
  document.getElementById("running").innerText = s.running ? "RUNNING" : "STOPPED";
  document.getElementById("iface").innerText = s.iface;
  document.getElementById("mode").innerText = s.mode;
  document.getElementById("target").innerText = s.game_target;
  document.getElementById("last_action").innerText = s.last_action;
  document.getElementById("updated").innerText = "Updated " + s.updated;
  document.getElementById("modeSelect").value = s.mode;
  document.getElementById("targetInput").value = s.game_target;
}

async function doAction(action){
  await fetch("/api/action", {method:"POST", headers:{"Content-Type":"application/json"}, body: JSON.stringify({action})});
  document.getElementById("logBox").innerText = "[ACTION] " + action + "\\n" + document.getElementById("logBox").innerText;
  refresh();
}

async function saveConfig(){
  const mode = document.getElementById("modeSelect").value;
  const game_target = document.getElementById("targetInput").value.trim();
  await fetch("/api/config", {method:"POST", headers:{"Content-Type":"application/json"}, body: JSON.stringify({mode, game_target})});
  document.getElementById("logBox").innerText = "[CONFIG] saved\\n" + document.getElementById("logBox").innerText;
  refresh();
}

refresh();
setInterval(refresh, 2000);
</script>
</body>
</html>
"""

@app.route("/")
def index():
    return render_template_string(HTML)

@app.route("/api/state")
def api_state():
    STATE["updated"] = time.strftime("%H:%M:%S")
    return jsonify(STATE)

@app.route("/api/action", methods=["POST"])
def api_action():
    action = request.get_json(force=True).get("action", "")
    if action == "start":
        STATE["running"] = True
    elif action == "stop":
        STATE["running"] = False
    elif action == "restart":
        STATE["running"] = True
    STATE["last_action"] = action
    STATE["updated"] = time.strftime("%H:%M:%S")
    return jsonify({"ok": True, "state": STATE})

@app.route("/api/config", methods=["POST"])
def api_config():
    data = request.get_json(force=True)
    STATE["mode"] = data.get("mode", STATE["mode"])
    STATE["game_target"] = data.get("game_target", STATE["game_target"])
    STATE["updated"] = time.strftime("%H:%M:%S")
    return jsonify({"ok": True, "state": STATE})

if __name__ == "__main__":
    print(">>> UI running on http://127.0.0.1:5000")
    app.run(host="0.0.0.0", port=5000, debug=True)
