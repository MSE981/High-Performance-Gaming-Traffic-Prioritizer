<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title>System Login</title>
    <style>
      body {
        font-family: sans-serif;
        background: #1a1a1a;
        color: white;
        display: flex;
        justify-content: center;
        align-items: center;
        height: 100vh;
        margin: 0;
        position: relative;
      }

      .login-box {
        background: #2d2d2d;
        padding: 40px;
        border-radius: 10px;
        text-align: center;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.8);
        width: 300px;
      }

      input {
        padding: 12px;
        margin: 15px 0;
        width: 100%;
        box-sizing: border-box;
        border-radius: 5px;
        border: 1px solid #555;
        background: #222;
        color: white;
      }

      button {
        padding: 12px;
        width: 100%;
        background: #007bff;
        color: white;
        border: none;
        cursor: pointer;
        border-radius: 5px;
        font-weight: bold;
        font-size: 16px;
        transition: 0.3s;
      }

      button:hover {
        background: #0056b3;
      }

      /* NEW: Global Footer CSS */
      .global-footer {
        position: absolute;
        bottom: 20px;
        width: 100%;
        text-align: center;
        color: #555;
        font-size: 12px;
        font-family: monospace;
      }

      .status-dot {
        color: #28a745;
        font-size: 10px;
        margin-right: 5px;
      }
    </style>
  </head>

  <body>
    <div class="login-box">
      <h2 style="color: #007bff; margin-top: 0">Traffic Console</h2>
      <form action="/api/login" method="POST">
        <input
          type="password"
          name="password"
          placeholder="Enter root password"
          required
        />
        <button type="submit">Initialize Link</button>
      </form>
    </div>

    <div class="global-footer">
      BMC Engine <%= systemVersion %> &copy; <%= currentYear %><br />
      <span class="status-dot">●</span> Secure Connection Established
    </div>
  </body>
</html>
