<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <title>Developer Terminal</title>
    <style>
        body {
            font-family: sans-serif;
            background: #1a1a1a;
            color: white;
            padding: 20px;
            margin: 0;
        }

        h1 {
            text-align: center;
            margin-bottom: 30px;
        }

        .navbar {
            background-color: #2d2d2d;
            overflow: hidden;
            border-radius: 8px;
            margin-bottom: 25px;
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.3);
            display: flex;
            justify-content: center;
            flex-wrap: wrap;
        }

        .navbar a {
            display: block;
            color: #ccc;
            text-align: center;
            padding: 14px 20px;
            text-decoration: none;
            font-weight: bold;
            transition: 0.3s;
        }

        .navbar a:hover {
            background-color: #444;
            color: white;
        }

        .navbar a.active {
            background-color: #dc3545;
            color: white;
        }

        .container {
            display: flex;
            flex-direction: column;
            align-items: center;
            max-width: 1000px;
            margin: 0 auto;
            gap: 20px;
        }

        .panel {
            background: #2d2d2d;
            padding: 20px;
            border-radius: 10px;
            width: 100%;
            box-sizing: border-box;
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.5);
        }

        h2 {
            margin-top: 0;
            border-bottom: 2px solid #dc3545;
            padding-bottom: 10px;
            color: #dc3545;
        }

        .console-output {
            background: #000;
            color: #00ff00;
            padding: 15px;
            border-radius: 5px 5px 0 0;
            font-family: 'Courier New', Courier, monospace;
            height: 400px;
            overflow-y: auto;
            border: 1px solid #444;
            border-bottom: none;
            white-space: pre-wrap;
            font-size: 14px;
        }

        .console-input-area {
            display: flex;
            background: #000;
            border: 1px solid #444;
            border-radius: 0 0 5px 5px;
            padding: 10px;
            align-items: center;
        }

        .prompt {
            color: #00ff00;
            font-family: 'Courier New', Courier, monospace;
            margin-right: 10px;
            font-weight: bold;
        }

        input {
            flex-grow: 1;
            background: transparent;
            border: none;
            color: #00ff00;
            font-family: 'Courier New', Courier, monospace;
            font-size: 15px;
            outline: none;
        }

        .warning-text {
            color: #888;
            font-size: 12px;
            margin-top: 10px;
            text-align: center;
        }
    </style>
</head>

<body>

    <h1>🚀 Core System Management (BMC)</h1>

    <div class="navbar">
        <a href="/">📊 Dashboard</a>
        <a href="/network">🌐 Network</a>
        <a href="/qos">🚦 QoS</a>
        <a href="/devices">📱 Devices</a>
        <a href="/logs">📈 Logs</a>
        <a href="/dev" class="active">🛠️ Dev</a>
        <a href="/security"> Security</a>
    </div>

    <div class="container">
        <div class="panel">
            <h2>⚠️ Root Access Terminal</h2>

            <div class="console-output" id="output-box">Welcome to the Developer Web Terminal.
                Authentication successful. Root privileges granted.
                Type a system command and press ENTER...
                --------------------------------------------------</div>

            <div class="console-input-area">
                <span class="prompt">admin@gaming-router:~$</span>
                <input type="text" id="cmd-input" placeholder="e.g., ipconfig, dir, ping 8.8.8.8" autocomplete="off"
                    autofocus>
            </div>

            <div class="warning-text">
                Warning: You have direct access to the host operating system. Execute commands with caution.
            </div>
        </div>
    </div>

    <script>
        const cmdInput = document.getElementById('cmd-input');
        const outputBox = document.getElementById('output-box');

        cmdInput.addEventListener('keypress', function (e) {
            if (e.key === 'Enter') {
                const command = cmdInput.value.trim();
                if (command === '') return;

                cmdInput.value = '';

                outputBox.innerText += '\n\nadmin@gaming-router:~$ ' + command + '\n';
                outputBox.innerText += 'Executing...';
                outputBox.scrollTop = outputBox.scrollHeight;

                const formData = new URLSearchParams();
                formData.append('command', command);

                fetch('/api/terminal', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                    body: formData.toString()
                })
                    .then(response => response.json())
                    .then(data => {
                        outputBox.innerText = outputBox.innerText.replace('Executing...', data.output);
                        outputBox.scrollTop = outputBox.scrollHeight;
                    })
                    .catch(error => {
                        outputBox.innerText = outputBox.innerText.replace('Executing...', 'System Error: ' + error);
                        outputBox.scrollTop = outputBox.scrollHeight;
                    });
            }
        });
    </script>

</body>

</html>