<!DOCTYPE html>
<html lang="en">
<head>
    <title>HPGTP - Interfaces</title>
    <%- include('partials/head') %>
    <style>
        .top-status-bar {
            display: flex;
            justify-content: space-between;
            padding-bottom: 10px;
            border-bottom: 2px solid #2a50a0;
            margin-bottom: 15px;
        }
        .shutdown-btn { color: #ff4d4d; font-weight: bold; cursor: pointer; }
        .small-stats { color: #00f0ff; font-family: monospace; }
        
        .interface-card {
            background: rgba(4, 15, 36, 0.4);
            border: 1px solid #1c3b80;
            border-radius: 8px;
            padding: 15px;
            margin-bottom: 15px;
            position: relative;
        }
        .interface-header {
            font-weight: bold;
            color: #fff;
            margin-bottom: 15px;
            font-size: 1.1rem;
        }
        .interface-status {
            position: absolute;
            top: 15px;
            right: 15px;
            color: #9ab4e0;
            font-size: 0.9rem;
        }
        
        .role-group {
            display: flex;
            gap: 10px;
        }
        .role-btn {
            flex: 1;
            padding: 10px;
            background: transparent;
            border: 1px solid #2a50a0;
            color: #cfdeff;
            text-align: center;
            border-radius: 4px;
            cursor: pointer;
            transition: 0.2s;
        }
        .role-btn.active {
            background: #00e0ff;
            color: #000;
            font-weight: bold;
            border-color: #00e0ff;
            box-shadow: 0 0 10px rgba(0, 224, 255, 0.5);
        }
        
        .advanced-options {
            margin-top: 30px;
            border-top: 1px solid #2a50a0;
            padding-top: 20px;
        }
        .advanced-title {
            color: #00f0ff;
            font-weight: bold;
            margin-bottom: 15px;
        }
        .checkbox-row {
            display: flex;
            align-items: center;
            margin-bottom: 15px;
            color: #9ab4e0;
            font-size: 0.9rem;
        }
        .custom-checkbox {
            width: 20px;
            height: 20px;
            border: 1px solid #2a50a0;
            border-radius: 4px;
            margin-right: 15px;
        }
        
        .bottom-actions {
            display: flex;
            justify-content: space-between;
            margin-top: 20px;
        }
    </style>
</head>
<body>
    <div class="app-container">
        <div class="top-status-bar">
            <div><span class="shutdown-btn">Shutdown</span> <span style="font-weight:bold; margin-left:10px;">HPGTP</span></div>
            <div class="small-stats">10.0 10.0 45°C</div>
        </div>

        <div class="page-title" style="margin-bottom:5px; color:#fff;">Network Interface Roles</div>
        <div style="color:#9ab4e0; font-size:0.9rem; margin-bottom:20px;">Assign a role to each detected interface. Exactly one must be set as Default Gateway.</div>

        <div class="interface-card">
            <div class="interface-header">eth0</div>
            <div class="interface-status">○ Down</div>
            <div class="role-group">
                <div class="role-btn">WAN</div>
                <div class="role-btn active">LAN</div>
                <div class="role-btn">Gateway</div>
                <div class="role-btn">Disabled</div>
            </div>
        </div>

        <div class="interface-card">
            <div class="interface-header">eth1</div>
            <div class="interface-status">○ Down</div>
            <div class="role-group">
                <div class="role-btn">WAN</div>
                <div class="role-btn">LAN</div>
                <div class="role-btn active">Gateway</div>
                <div class="role-btn">Disabled</div>
            </div>
        </div>

        <div class="interface-card">
            <div class="interface-header">eth2</div>
            <div class="interface-status">○ Down</div>
            <div class="role-group">
                <div class="role-btn">WAN</div>
                <div class="role-btn">LAN</div>
                <div class="role-btn">Gateway</div>
                <div class="role-btn active">Disabled</div>
            </div>
        </div>

        <div class="interface-card">
            <div class="interface-header">eth3</div>
            <div class="interface-status">○ Down</div>
            <div class="role-group">
                <div class="role-btn">WAN</div>
                <div class="role-btn">LAN</div>
                <div class="role-btn">Gateway</div>
                <div class="role-btn active">Disabled</div>
            </div>
        </div>

        <div class="advanced-options">
            <div class="advanced-title">Advanced Options</div>
            
            <div class="checkbox-row">
                <div style="width: 200px;">Spanning Tree Protocol:</div>
                <div class="custom-checkbox"></div>
                <div>Enable STP</div>
            </div>
            
            <div class="checkbox-row">
                <div style="width: 200px;">IGMP Snooping:</div>
                <div class="custom-checkbox"></div>
                <div>Enable IGMP Snooping</div>
            </div>
            
            <div class="bottom-actions">
                <button class="btn btn-secondary">Refresh</button>
                <div style="display:flex; gap:10px;">
                    <button class="btn btn-secondary" style="border-radius:20px; padding:8px 20px;">Reset</button>
                    <button class="btn" style="border-radius:20px; padding:8px 20px;">Save / Apply</button>
                </div>
            </div>
        </div>

    </div>

    <%- include('partials/bottom_nav', { activeTab: 'interfaces' }) %>
</body>
</html>
