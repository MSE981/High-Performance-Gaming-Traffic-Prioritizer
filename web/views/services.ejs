<!DOCTYPE html>
<html lang="en">
<head>
    <title>HPGTP - Services</title>
    <%- include('partials/head') %>
    <style>
        .top-status-bar {
            display: flex;
            justify-content: space-between;
            padding-bottom: 10px;
            border-bottom: 2px solid #2a50a0;
            margin-bottom: 15px;
        }
        .shutdown-btn { color: #ff4d4d; font-weight: bold; cursor: pointer; }
        .small-stats { color: #00f0ff; font-family: monospace; }

        .service-row {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 15px;
            border: 1px solid #1c3b80;
            border-radius: 6px;
            margin-bottom: 15px;
            background: rgba(4, 15, 36, 0.4);
        }
        
        .service-info {
            display: flex;
            align-items: center;
            flex: 1;
        }
        
        .service-toggle {
            width: 30px;
            height: 30px;
            border-radius: 6px;
            margin-right: 15px;
        }
        .service-toggle.on { background-color: #00f0ff; }
        .service-toggle.off { background-color: transparent; border: 2px solid #1c3b80; }
        
        .service-details {
            display: flex;
            flex-direction: column;
        }
        
        .service-name { font-weight: bold; color: #fff; font-size: 1.1rem; }
        .service-desc { color: #9ab4e0; font-size: 0.85rem; margin-top: 5px; }

        .service-actions {
            display: flex;
            align-items: center;
            gap: 15px;
        }
        
        .status-badge {
            padding: 8px 15px;
            border-radius: 6px;
            font-size: 0.9rem;
            font-weight: bold;
            display: flex;
            align-items: center;
            gap: 8px;
            border: 1px solid #1c3b80;
        }
        .status-badge.running { color: #00ff88; }
        .status-badge.stopped { color: #ff4d4d; border-color: #ff4d4d; }
        
    </style>
</head>
<body>
    <div class="app-container">
        <div class="top-status-bar">
            <div><span class="shutdown-btn">Shutdown</span> <span style="font-weight:bold; margin-left:10px;">HPGTP</span></div>
            <div class="small-stats">10.0 10.0 46°C</div>
        </div>

        <div class="page-title" style="margin-bottom:5px; color:#fff;">Services</div>
        <div style="color:#9ab4e0; font-size:0.9rem; margin-bottom:20px;">Enable or disable core network services. Changes take effect immediately, no restart required.</div>

        <div class="service-row">
            <div class="service-info">
                <div class="service-toggle on"></div>
                <div class="service-details">
                    <span class="service-name">NAT (Network Address Translation)</span>
                    <span class="service-desc">Zero-copy SNAT/DNAT engine</span>
                </div>
            </div>
            <div class="service-actions">
                <div class="status-badge running">● Running</div>
            </div>
        </div>

        <div class="service-row">
            <div class="service-info">
                <div class="service-toggle on"></div>
                <div class="service-details">
                    <span class="service-name">DHCP (Dynamic Host Config)</span>
                    <span class="service-desc">Automatically assigns IP addresses to LAN clients</span>
                </div>
            </div>
            <div class="service-actions">
                <button class="btn btn-secondary">Set DHCP</button>
                <div class="status-badge running">● Running</div>
            </div>
        </div>

        <div class="service-row">
            <div class="service-info">
                <div class="service-toggle on"></div>
                <div class="service-details">
                    <span class="service-name">DNS Cache</span>
                    <span class="service-desc">Local DNS cache for fast resolution</span>
                </div>
            </div>
            <div class="service-actions">
                <button class="btn btn-secondary">Set DNS</button>
                <div class="status-badge running">● Running</div>
            </div>
        </div>

        <div class="service-row">
            <div class="service-info">
                <div class="service-toggle on"></div>
                <div class="service-details">
                    <span class="service-name">Firewall</span>
                    <span class="service-desc">Inbound traffic filter rule engine</span>
                </div>
            </div>
            <div class="service-actions">
                <div class="status-badge running">● Running</div>
            </div>
        </div>

        <div class="service-row">
            <div class="service-info">
                <div class="service-toggle off"></div>
                <div class="service-details">
                    <span class="service-name">UPnP (Plug & Play)</span>
                    <span class="service-desc">Automatic port mapping for NAT traversal</span>
                </div>
            </div>
            <div class="service-actions">
                <div class="status-badge stopped">○ Stopped</div>
            </div>
        </div>
        
    </div>

    <%- include('partials/bottom_nav', { activeTab: 'services' }) %>
</body>
</html>
