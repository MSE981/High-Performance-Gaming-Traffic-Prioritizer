<!DOCTYPE html>
<html lang="en">
  <head>
    <title>HPGTP - Services</title>
    <%- include('partials/head') %>
    <style>
      .top-status-bar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 24px;
      }

      .service-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 20px;
        background: #ffffff;
        border: 1px solid #e2e8f0;
        border-radius: 12px;
        margin-bottom: 16px;
        box-shadow: 0 1px 2px rgba(0, 0, 0, 0.02);
        transition:
          box-shadow 0.2s,
          border-color 0.2s;
      }
      .service-row:hover {
        border-color: #cbd5e1;
        box-shadow: 0 4px 6px rgba(0, 0, 0, 0.04);
      }

      .service-info {
        display: flex;
        align-items: center;
        flex: 1;
      }

      .service-toggle {
        width: 44px;
        height: 24px;
        border-radius: 12px;
        margin-right: 16px;
        position: relative;
        background-color: #e2e8f0;
        cursor: pointer;
        transition: background-color 0.2s;
      }
      .service-toggle::after {
        content: "";
        position: absolute;
        top: 2px;
        left: 2px; /* Off state */
        width: 20px;
        height: 20px;
        background: #ffffff;
        border-radius: 50%;
        box-shadow: 0 1px 2px rgba(0, 0, 0, 0.2);
        transition: left 0.2s;
      }
      .service-toggle.on {
        background-color: #059669; /* Emerald */
      }
      .service-toggle.on::after {
        left: 22px;
      }

      .service-details {
        display: flex;
        flex-direction: column;
      }
      .service-name {
        font-weight: 600;
        color: #0f172a;
        font-size: 1.05rem;
      }
      .service-desc {
        color: #64748b;
        font-size: 0.85rem;
        margin-top: 4px;
      }

      .service-actions {
        display: flex;
        align-items: center;
        gap: 16px;
      }

      .status-badge {
        padding: 6px 12px;
        border-radius: 20px;
        font-size: 0.8rem;
        font-weight: 600;
        display: flex;
        align-items: center;
        gap: 6px;
        background: #f1f5f9;
      }
      .status-badge.running {
        color: #059669;
      }
      .status-badge.stopped {
        color: #dc2626;
      }
    </style>
  </head>
  <body>
    <div class="app-container">
      <div class="top-status-bar">
        <div>
          <span class="text-danger font-semibold" style="cursor: pointer"
            >Shutdown</span
          >
          <span
            class="font-semibold"
            style="margin-left: 12px; font-size: 1.1rem"
            >HPGTP</span
          >
        </div>
        <div class="font-mono text-secondary">10.0 10.0 46°C</div>
      </div>

      <div class="page-title" style="margin-bottom: 8px">Services</div>
      <div
        class="text-secondary"
        style="font-size: 0.9rem; margin-bottom: 24px"
      >
        Enable or disable core network services. Changes take effect
        immediately, no restart required.
      </div>

      <div class="service-row">
        <div class="service-info">
          <div class="service-toggle on"></div>
          <div class="service-details">
            <span class="service-name">NAT (Network Address Translation)</span>
            <span class="service-desc">Zero-copy SNAT/DNAT engine</span>
          </div>
        </div>
        <div class="service-actions">
          <div class="status-badge running">● Running</div>
        </div>
      </div>

      <div class="service-row">
        <div class="service-info">
          <div class="service-toggle on"></div>
          <div class="service-details">
            <span class="service-name">DHCP (Dynamic Host Config)</span>
            <span class="service-desc"
              >Automatically assigns IP addresses to LAN clients</span
            >
          </div>
        </div>
        <div class="service-actions">
          <button class="btn btn-secondary">Set DHCP</button>
          <div class="status-badge running">● Running</div>
        </div>
      </div>

      <div class="service-row">
        <div class="service-info">
          <div class="service-toggle on"></div>
          <div class="service-details">
            <span class="service-name">DNS Cache</span>
            <span class="service-desc"
              >Local DNS cache for fast resolution</span
            >
          </div>
        </div>
        <div class="service-actions">
          <button class="btn btn-secondary">Set DNS</button>
          <div class="status-badge running">● Running</div>
        </div>
      </div>

      <div class="service-row">
        <div class="service-info">
          <div class="service-toggle on"></div>
          <div class="service-details">
            <span class="service-name">Firewall</span>
            <span class="service-desc">Inbound traffic filter rule engine</span>
          </div>
        </div>
        <div class="service-actions">
          <div class="status-badge running">● Running</div>
        </div>
      </div>

      <div class="service-row">
        <div class="service-info">
          <div class="service-toggle"></div>
          <div class="service-details">
            <span class="service-name">UPnP (Plug & Play)</span>
            <span class="service-desc"
              >Automatic port mapping for NAT traversal</span
            >
          </div>
        </div>
        <div class="service-actions">
          <div class="status-badge stopped">○ Stopped</div>
        </div>
      </div>
    </div>

    <%- include('partials/bottom_nav', { activeTab: 'services' }) %>
  </body>
</html>
