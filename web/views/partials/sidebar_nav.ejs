<style>
  .sidebar-nav {
    position: fixed;
    top: 0;
    left: 0;
    bottom: 0;
    width: 250px;
    background-color: #ffffff;
    border-right: 1px solid #e2e8f0;
    display: flex;
    flex-direction: column;
    padding: 32px 0;
    box-shadow: 1px 0 10px rgba(0, 0, 0, 0.03);
    z-index: 1000;
  }

  .sidebar-brand {
    font-size: 1.5rem;
    font-weight: 700;
    color: #0f172a;
    padding: 0 24px;
    margin-bottom: 40px;
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .sidebar-brand-icon {
    background: #4f46e5;
    color: white;
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 8px;
    font-size: 1.2rem;
  }

  .nav-item {
    display: flex;
    align-items: center;
    text-decoration: none;
    color: #64748b; /* Slate-500 */
    font-size: 0.95rem;
    font-weight: 500;
    padding: 14px 24px;
    transition: all 0.2s ease;
    border-left: 3px solid transparent;
  }

  .nav-item.active {
    color: #4f46e5; /* Primary Indigo */
    background: #f8fafc; /* Very subtle highlight */
    border-left-color: #4f46e5;
  }

  .nav-icon {
    font-size: 1.2rem;
    margin-right: 16px;
    width: 24px;
    text-align: center;
  }

  .nav-item:hover:not(.active) {
    color: #334155;
    background: #f1f5f9;
  }
</style>

<div class="sidebar-nav">
  <div class="sidebar-brand">
    <div class="sidebar-brand-icon">⚡</div>
    HPGTP
  </div>

  <a
    href="/dashboard"
    class="nav-item <%= typeof activeTab !== 'undefined' && activeTab === 'overview' ? 'active' : '' %>"
  >
    <span class="nav-icon">⌂</span>
    <span>Overview</span>
  </a>
  <a
    href="/qos"
    class="nav-item <%= typeof activeTab !== 'undefined' && activeTab === 'qos' ? 'active' : '' %>"
  >
    <span class="nav-icon">⚡</span>
    <span>QoS</span>
  </a>
  <a
    href="/services"
    class="nav-item <%= typeof activeTab !== 'undefined' && activeTab === 'services' ? 'active' : '' %>"
  >
    <span class="nav-icon">⚙️</span>
    <span>Services</span>
  </a>
  <a
    href="/devices"
    class="nav-item <%= typeof activeTab !== 'undefined' && activeTab === 'devices' ? 'active' : '' %>"
  >
    <span class="nav-icon">📱</span>
    <span>Devices</span>
  </a>
  <a
    href="/interfaces"
    class="nav-item <%= typeof activeTab !== 'undefined' && activeTab === 'interfaces' ? 'active' : '' %>"
  >
    <span class="nav-icon">🌐</span>
    <span>Interfaces</span>
  </a>
</div>
