<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<script src="https://cdn.jsdelivr.net/npm/echarts/dist/echarts.min.js"></script>
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

<style>
    /* Global Reset & Base Theme */
    body, html {
        margin: 0;
        padding: 0;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        background-color: #030a16;
        color: #e0f2ff;
        min-height: 100vh;
        -webkit-font-smoothing: antialiased;
        user-select: none;
    }

    /* Screen layout wrapper (allows space for bottom nav) */
    .app-container {
        padding: 20px;
        padding-bottom: 90px; /* Space for the bottom nav */
        padding-top: 10px;
    }

    /* Headers */
    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 20px;
    }

    .page-title {
        font-size: 1.2rem;
        font-weight: 600;
        color: #a0c4ff;
    }

    /* Panels / Cards */
    .panel {
        background: rgba(14, 38, 92, 0.4);
        border: 1px solid #1c3b80;
        border-radius: 8px;
        padding: 15px;
        margin-bottom: 20px;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.3);
    }

    .panel-header {
        font-size: 1.1rem;
        font-weight: bold;
        color: #ffffff;
        margin-bottom: 15px;
        border-bottom: 1px solid #2a50a0;
        padding-bottom: 8px;
    }

    /* Buttons */
    .btn {
        background: #00e0ff;
        color: #000;
        border: none;
        padding: 8px 16px;
        border-radius: 4px;
        font-weight: bold;
        cursor: pointer;
        transition: 0.2s;
    }

    .btn:hover {
        background: #00b3cc;
    }

    .btn-secondary {
        background: #1c3b80;
        color: #e0f2ff;
        border: 1px solid #3a6bd4;
    }

    /* Inputs & Toggles container layout */
    .form-group {
        margin-bottom: 15px;
    }

    .form-label {
        display: block;
        margin-bottom: 5px;
        color: #9ab4e0;
        font-size: 0.9rem;
    }

    .form-control {
        width: 100%;
        background: rgba(4, 15, 36, 0.6);
        border: 1px solid #2a50a0;
        color: #fff;
        padding: 10px;
        border-radius: 4px;
        box-sizing: border-box;
    }

    /* Highlight Colors */
    .text-cyan { color: #00f0ff; }
    .text-green { color: #00ff88; }
    .text-yellow { color: #ffcc00; }
    .text-red { color: #ff4444; }

    /* Tables */
    table.data-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 0.9rem;
    }
    table.data-table th, table.data-table td {
        padding: 10px;
        text-align: left;
    }
    table.data-table th {
        border-bottom: 2px solid #2a50a0;
        color: #9ab4e0;
    }
    table.data-table td {
        border-bottom: 1px solid #1c3b80;
    }
</style>
