<!DOCTYPE html>
<html lang="en">
<head>
    <title>HPGTP - QoS</title>
    <%- include('partials/head') %>
    <style>
        .top-status-bar {
            display: flex;
            justify-content: space-between;
            padding-bottom: 10px;
            border-bottom: 2px solid #2a50a0;
            margin-bottom: 15px;
        }
        .shutdown-btn { color: #ff4d4d; font-weight: bold; cursor: pointer; }
        .small-stats { color: #00f0ff; font-family: monospace; }
        
        .toggle-row {
            display: flex;
            align-items: center;
            margin-bottom: 20px;
        }
        .custom-toggle {
            width: 30px;
            height: 30px;
            background-color: #00f0ff;
            border-radius: 6px;
            margin-right: 15px;
            /* Placeholder for actual toggle visual */
        }
        
        .slider-container {
            margin: 20px 0;
            padding: 15px 0;
        }
        .slider {
            -webkit-appearance: none;
            width: 100%;
            height: 8px;
            background: #1c3b80;
            outline: none;
            border-radius: 4px;
        }
        .slider::-webkit-slider-thumb {
            -webkit-appearance: none;
            appearance: none;
            width: 25px;
            height: 25px;
            background: #fff;
            border-radius: 4px;
            cursor: pointer;
        }
        
    </style>
</head>
<body>
    <div class="app-container">
        <div class="top-status-bar">
            <div><span class="shutdown-btn">Shutdown</span> <span style="font-weight:bold; margin-left:10px;">HPGTP</span></div>
            <div class="small-stats">10.0 10.0 45°C</div>
        </div>

        <div class="page-title" style="margin-bottom:20px; color:#fff;">QoS & Traffic Control</div>

        <div class="toggle-row">
            <div class="custom-toggle"></div>
            <div style="font-weight:bold; color:#fff;">Enable Gaming Traffic Acceleration (Heuristic Priority Scheduling)</div>
        </div>

        <div class="panel">
            <div class="panel-header">Global Bandwidth Limits</div>
            <form action="/update_qos_settings" method="POST">
                <div style="display:flex; align-items:center; margin-bottom:10px;">
                    <label class="form-label" style="width:200px; margin:0;">Download Limit (Mbps):</label>
                    <input type="number" name="limit" class="form-control" value="<%= config.bandwidth_limit || 500 %>" style="flex:1;">
                </div>
                <div style="display:flex; align-items:center;">
                    <label class="form-label" style="width:200px; margin:0;">Upload Limit (Mbps):</label>
                    <input type="number" name="up_limit" class="form-control" value="50" style="flex:1;">
                </div>
            </form>
        </div>

        <div class="panel">
            <div class="panel-header">Real-Time Throttle</div>
            <div class="slider-container">
                <input type="range" min="0" max="100" value="85" class="slider" id="throttle-slider">
                <div style="display:flex; justify-content:space-between; margin-top:10px; color:#9ab4e0; font-size:0.9rem;">
                    <span>0%</span><span>100%</span>
                </div>
            </div>
        </div>

        <div class="panel">
            <div class="panel-header">Game Port Whitelist</div>
            <table class="data-table" style="margin-bottom:20px;">
                <thead>
                    <tr>
                        <th>Port / Range</th>
                        <th>Protocol</th>
                        <th>Description</th>
                    </tr>
                </thead>
                <tbody>
                    <tr><td>1119</td><td>TCP/UDP</td><td>Blizzard Battle.net</td></tr>
                    <tr><td>6112</td><td>TCP/UDP</td><td>Blizzard / StarCraft</td></tr>
                    <tr><td>3074</td><td>UDP</td><td>Call of Duty</td></tr>
                    <tr><td>3659</td><td>UDP</td><td>EA / Origin</td></tr>
                    <tr><td>8080</td><td>TCP</td><td>Game HTTP services</td></tr>
                    <tr><td>7777-7778</td><td>UDP</td><td>Garena / Arena games</td></tr>
                    <tr><td>4380</td><td>UDP</td><td>Steam (In-Home Streaming)</td></tr>
                    <tr><td>27031-27036</td><td>UDP</td><td>Steam Remote Play</td></tr>
                    <tr><td>27015</td><td>UDP</td><td>Steam / Valve</td></tr>
                    <tr><td>443</td><td>TCP</td><td>HTTPS / Secure game APIs</td></tr>
                </tbody>
            </table>
            <button class="btn btn-secondary">Edit Whitelist...</button>
        </div>
    </div>

    <%- include('partials/bottom_nav', { activeTab: 'qos' }) %>
</body>
</html>