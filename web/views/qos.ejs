<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <title>Traffic QoS Management</title>
    <style>
        body {
            font-family: sans-serif;
            background: #1a1a1a;
            color: white;
            padding: 20px;
            margin: 0;
        }

        h1 {
            text-align: center;
            margin-bottom: 30px;
        }

        .navbar {
            background-color: #2d2d2d;
            overflow: hidden;
            border-radius: 8px;
            margin-bottom: 25px;
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.3);
            display: flex;
            justify-content: center;
            flex-wrap: wrap;
        }

        .navbar a {
            display: block;
            color: #ccc;
            text-align: center;
            padding: 14px 20px;
            text-decoration: none;
            font-weight: bold;
            transition: 0.3s;
        }

        .navbar a:hover {
            background-color: #444;
            color: white;
        }

        .navbar a.active {
            background-color: #28a745;
            color: white;
        }

        .container {
            display: flex;
            flex-direction: column;
            align-items: center;
            max-width: 800px;
            margin: 0 auto;
            gap: 20px;
        }

        .panel {
            background: #2d2d2d;
            padding: 30px;
            border-radius: 10px;
            width: 100%;
            box-sizing: border-box;
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.3);
        }

        h2 {
            margin-top: 0;
            border-bottom: 2px solid #444;
            padding-bottom: 10px;
            color: #28a745;
        }

        label {
            display: block;
            margin-top: 20px;
            margin-bottom: 8px;
            color: #ccc;
            font-weight: bold;
        }

        input,
        select {
            padding: 12px;
            width: 100%;
            box-sizing: border-box;
            border-radius: 5px;
            border: 1px solid #555;
            background: #222;
            color: white;
            font-size: 16px;
        }

        input:focus,
        select:focus {
            outline: none;
            border-color: #28a745;
        }

        button {
            padding: 15px;
            width: 100%;
            background: #28a745;
            color: white;
            border: none;
            cursor: pointer;
            border-radius: 5px;
            font-weight: bold;
            font-size: 18px;
            margin-top: 30px;
            transition: 0.3s;
        }

        button:hover {
            background: #218838;
        }

        .hint {
            font-size: 12px;
            color: #888;
            margin-top: 5px;
        }
    </style>
</head>

<body>

    <h1>🚀 Core System Management (BMC)</h1>

    <div class="navbar">
        <a href="/">📊 Dashboard</a>
        <a href="/network">🌐 Network</a>
        <a href="/wifi">📶 Wi-Fi</a>
        <a href="/qos" class="active">🚦 QoS</a>
        <a href="/devices">📱 Devices</a>
        <a href="/logs">📈 Logs</a>
        <a href="/dev">🛠️ Dev</a>
        <a href="/more">⚙️ More</a>
    </div>

    <div class="container">
        <div class="panel">
            <h2>Quality of Service (QoS) Engine</h2>

            <form action="/update_qos_settings" method="POST">

                <label>System Optimization Mode</label>
                <select name="mode">
                    <option value="gaming" <%=config.traffic_mode==='gaming' ? 'selected' : '' %>>Gaming Priority (Low
                        Latency / UDP Focus)</option>
                    <option value="streaming" <%=config.traffic_mode==='streaming' ? 'selected' : '' %>>Streaming Mode
                        (High Throughput / TCP Focus)</option>
                </select>
                <div class="hint">Select Gaming for competitive matches, Streaming for Netflix/YouTube.</div>

                <label>Global Bandwidth Limit (Mbps)</label>
                <input type="number" name="limit" value="<%= config.bandwidth_limit %>" required min="1" max="10000">
                <div class="hint">Prevents background downloads from consuming all your internet speed.</div>

                <label>Priority Game Port</label>
                <input type="number" name="target_port" value="<%= config.target_port %>" required min="1" max="65535">
                <div class="hint">Traffic on this specific port will bypass the queue. Default CS2/Source port: 27015.
                </div>

                <button type="submit">Apply Traffic Rules</button>

            </form>
        </div>
    </div>

</body>

</html>