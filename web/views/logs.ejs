<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <title>System Logs</title>
    <style>
        body {
            font-family: sans-serif;
            background: #1a1a1a;
            color: white;
            padding: 20px;
            margin: 0;
        }

        h1 {
            text-align: center;
            margin-bottom: 30px;
        }

        .navbar {
            background-color: #2d2d2d;
            overflow: hidden;
            border-radius: 8px;
            margin-bottom: 25px;
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.3);
            display: flex;
            justify-content: center;
        }

        .navbar a {
            display: block;
            color: #ccc;
            text-align: center;
            padding: 14px 20px;
            text-decoration: none;
            font-weight: bold;
            transition: 0.3s;
        }

        .navbar a:hover {
            background-color: #444;
            color: white;
        }

        .navbar a.active {
            background-color: #28a745;
            color: white;
        }

        .container {
            display: flex;
            flex-direction: column;
            align-items: center;
            max-width: 1000px;
            margin: 0 auto;
            gap: 20px;
        }

        .panel {
            background: #2d2d2d;
            padding: 30px;
            border-radius: 10px;
            width: 100%;
            box-sizing: border-box;
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.3);
        }

        h2 {
            margin-top: 0;
            border-bottom: 2px solid #444;
            padding-bottom: 10px;
            color: #28a745;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .log-window {
            background: #0c0c0c;
            color: #ccc;
            padding: 20px;
            border-radius: 5px;
            font-family: 'Courier New', Courier, monospace;
            height: 400px;
            overflow-y: auto;
            border: 1px solid #444;
        }

        .log-entry {
            margin-bottom: 8px;
            line-height: 1.5;
            border-bottom: 1px dashed #222;
            padding-bottom: 4px;
        }

        .log-time {
            color: #888;
            margin-right: 15px;
        }

        .level-INFO {
            color: #28a745;
            font-weight: bold;
            margin-right: 10px;
        }

        .level-WARNING {
            color: #ffc107;
            font-weight: bold;
            margin-right: 10px;
        }

        .level-ERROR {
            color: #dc3545;
            font-weight: bold;
            margin-right: 10px;
        }

        .refresh-btn {
            background: #007bff;
            color: white;
            border: none;
            padding: 8px 15px;
            border-radius: 5px;
            cursor: pointer;
            font-size: 14px;
            font-weight: bold;
            transition: 0.3s;
        }

        .refresh-btn:hover {
            background: #0056b3;
        }
    </style>
</head>

<body>

    <h1>🚀 Core System Management (BMC)</h1>

    <div class="navbar">
        <a href="/">📊 Dashboard</a>
        <a href="/network">🌐 Network</a>
        <a href="/qos">🚦 Traffic QoS</a>
        <a href="/devices">📱 Devices</a>
        <a href="/logs" class="active">📈 Logs</a>
        <a href="/dev">🛠️ Developer</a>
    </div>

    <div class="container">
        <div class="panel">
            <h2>
                System Event Logs
                <button class="refresh-btn" onclick="location.reload()">🔄 Refresh Logs</button>
            </h2>

            <div class="log-window">
                <% logs.forEach(function(log) { %>
                    <div class="log-entry">
                        <span class="log-time">[<%= log.timestamp %>]</span>
                        <span class="level-<%= log.level %>">[<%= log.level %>]</span>
                        <span class="log-message">
                            <%= log.message %>
                        </span>
                    </div>
                    <% }); %>
            </div>
        </div>
    </div>

</body>

</html>