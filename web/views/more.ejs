<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <title>More Features</title>
    <style>
        body {
            font-family: sans-serif;
            background: #1a1a1a;
            color: white;
            padding: 20px;
            margin: 0;
        }

        h1 {
            text-align: center;
            margin-bottom: 30px;
        }

        /* Top Navbar */
        .navbar {
            background-color: #2d2d2d;
            overflow: hidden;
            border-radius: 8px;
            margin-bottom: 25px;
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.3);
            display: flex;
            justify-content: center;
        }

        .navbar a {
            display: block;
            color: #ccc;
            text-align: center;
            padding: 14px 20px;
            text-decoration: none;
            font-weight: bold;
            transition: 0.3s;
        }

        .navbar a:hover {
            background-color: #444;
            color: white;
        }

        .navbar a.active {
            background-color: #17a2b8;
            color: white;
        }

        /* Huawei-like Cyan color */

        /* Huawei-style Layout (Sidebar + Main Content) */
        .layout-container {
            display: grid;
            grid-template-columns: 250px 1fr;
            gap: 20px;
            max-width: 1200px;
            margin: 0 auto;
        }

        /* Sidebar Menu */
        .sidebar {
            background: #2d2d2d;
            border-radius: 8px;
            padding: 15px 0;
            height: fit-content;
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.3);
        }

        .sidebar-header {
            padding: 0 20px 10px 20px;
            color: #17a2b8;
            font-size: 18px;
            font-weight: bold;
            border-bottom: 1px solid #444;
            margin-bottom: 10px;
        }

        .sidebar ul {
            list-style-type: none;
            padding: 0;
            margin: 0;
        }

        .sidebar li a {
            display: block;
            padding: 15px 20px;
            color: #ccc;
            text-decoration: none;
            border-left: 4px solid transparent;
            transition: 0.2s;
        }

        .sidebar li a:hover {
            background: #333;
            color: white;
        }

        .sidebar li a.active-menu {
            background: #333;
            color: #17a2b8;
            border-left: 4px solid #17a2b8;
            font-weight: bold;
        }

        /* Main Content Panel */
        .main-panel {
            background: #2d2d2d;
            border-radius: 8px;
            padding: 30px;
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.3);
        }

        .main-panel h2 {
            margin-top: 0;
            border-bottom: 2px solid #444;
            padding-bottom: 10px;
            color: white;
        }

        /* Forms & Buttons */
        label {
            display: block;
            margin-top: 20px;
            margin-bottom: 8px;
            color: #ccc;
            font-weight: bold;
        }

        input {
            padding: 12px;
            width: 100%;
            box-sizing: border-box;
            border-radius: 5px;
            border: 1px solid #555;
            background: #222;
            color: white;
            font-size: 16px;
            margin-bottom: 10px;
        }

        input:focus {
            outline: none;
            border-color: #17a2b8;
        }

        .btn-primary {
            padding: 12px 20px;
            background: #17a2b8;
            color: white;
            border: none;
            cursor: pointer;
            border-radius: 5px;
            font-weight: bold;
            font-size: 16px;
            transition: 0.3s;
        }

        .btn-primary:hover {
            background: #138496;
        }

        .btn-danger {
            padding: 12px 20px;
            background: #dc3545;
            color: white;
            border: none;
            cursor: pointer;
            border-radius: 5px;
            font-weight: bold;
            font-size: 16px;
            transition: 0.3s;
        }

        .btn-danger:hover {
            background: #c82333;
        }

        .alert-success {
            background: rgba(40, 167, 69, 0.2);
            border: 1px solid #28a745;
            color: #28a745;
            padding: 10px;
            border-radius: 5px;
            margin-bottom: 20px;
            display: none;
        }
    </style>
</head>

<body>

    <h1>🚀 Core System Management (BMC)</h1>

    <div class="navbar">
        <a href="/">📊 Dashboard</a>
        <a href="/network">🌐 Network</a>
        <a href="/qos">🚦 QoS</a>
        <a href="/devices">📱 Devices</a>
        <a href="/logs">📈 Logs</a>
        <a href="/dev">🛠️ Dev</a>
        <a href="/more" class="active">⚙️ More</a>
    </div>

    <div class="layout-container">
        <div class="sidebar">
            <div class="sidebar-header">System Settings</div>
            <ul>
                <li><a href="#password" class="active-menu">🔑 Change Password</a></li>
                <li><a href="#backup">💾 Backup & Restore</a></li>
                <li><a href="#reboot">🔄 Reboot System</a></li>
            </ul>
        </div>

        <div class="main-panel">
            <h2>Account Security</h2>
            <div class="alert-success" id="success-msg">Password updated successfully!</div>

            <form action="/api/change_password" method="POST">
                <label>Current Password</label>
                <input type="password" name="old_password" required placeholder="Enter current admin password">

                <label>New Password</label>
                <input type="password" name="new_password" required placeholder="Enter new strong password">

                <button type="submit" class="btn-primary" style="margin-top: 15px;">Save Changes</button>
            </form>

            <h2 style="margin-top: 50px; color: #dc3545;">Danger Zone</h2>
            <p style="color: #ccc;">Restarting the system will temporarily disconnect all network clients.</p>
            <form action="/api/reboot" method="POST"
                onsubmit="return confirm('Are you sure you want to reboot the system?');">
                <button type="submit" class="btn-danger">Reboot Router Now</button>
            </form>
        </div>
    </div>

</body>

</html>