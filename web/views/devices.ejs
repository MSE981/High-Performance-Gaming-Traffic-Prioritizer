<!DOCTYPE html>
<html lang="en">
<head>
    <title>HPGTP - Devices</title>
    <%- include('partials/head') %>
    <style>
        .top-status-bar {
            display: flex;
            justify-content: space-between;
            padding-bottom: 10px;
            border-bottom: 2px solid #2a50a0;
            margin-bottom: 15px;
        }
        .shutdown-btn { color: #ff4d4d; font-weight: bold; cursor: pointer; }
        .small-stats { color: #00f0ff; font-family: monospace; }
        
        .device-card {
            background: rgba(4, 15, 36, 0.4);
            border: 1px solid #1c3b80;
            border-radius: 6px;
            margin-bottom: 15px;
        }
        .device-header {
            padding: 10px 15px;
            border-bottom: 1px solid #1c3b80;
            font-family: monospace;
            background: rgba(30, 100, 255, 0.1);
        }
        .device-header span.ip { font-weight: bold; color: #fff; font-size: 1.1rem; margin-right: 10px; }
        .device-header span.mac { color: #9ab4e0; font-size: 0.9rem; }
        
        .device-body { padding: 15px; }
        
        .toggle-group {
            display: flex;
            gap: 15px;
            margin-bottom: 15px;
        }
        .toggle-btn {
            display: flex;
            align-items: center;
            background: rgba(4, 15, 36, 0.6);
            border: 1px solid #1c3b80;
            padding: 8px 15px;
            border-radius: 4px;
            color: #fff;
            cursor: pointer;
        }
        .toggle-box {
            width: 20px;
            height: 20px;
            border-radius: 4px;
            margin-right: 10px;
        }
        .toggle-box.active { background-color: #00f0ff; }
        .toggle-box.inactive { border: 1px solid #2a50a0; background: transparent; }
        
        .rate-limit-row {
            display: flex;
            align-items: center;
            margin-bottom: 10px;
        }
        .rate-btn {
            background: #1c3b80;
            border: 1px solid #2a50a0;
            color: #00f0ff;
            width: 35px;
            height: 35px;
            display: flex;
            justify-content: center;
            align-items: center;
            border-radius: 4px;
            cursor: pointer;
            font-size: 1.2rem;
        }
        .rate-input {
            flex: 1;
            background: rgba(30, 100, 255, 0.2);
            border: 1px solid #1c3b80;
            color: #00ff88;
            height: 35px;
            display: flex;
            justify-content: center;
            align-items: center;
            margin: 0 10px;
            border-radius: 4px;
            font-family: monospace;
        }
        
    </style>
</head>
<body>
    <div class="app-container">
        <div class="top-status-bar">
            <div><span class="shutdown-btn">Shutdown</span> <span style="font-weight:bold; margin-left:10px;">HPGTP</span></div>
            <div class="small-stats">10.0 10.0 45°C</div>
        </div>

        <div class="page-title" style="margin-bottom:5px; color:#fff;">Device Management</div>
        <div style="color:#9ab4e0; font-size:0.9rem; margin-bottom:20px;">Lists all active devices on the subnet. Configure access and rate limits, then click Apply All.</div>

        <div class="device-card">
            <div class="device-header">
                <span class="ip">192.168.3.14</span>
                <span class="mac">b6:b1:30:dc:93:27</span>
            </div>
            <div class="device-body">
                <div class="toggle-group">
                    <div class="toggle-btn"><div class="toggle-box active"></div> Allow Access</div>
                    <div class="toggle-btn"><div class="toggle-box inactive"></div> Rate Limit</div>
                </div>
                <div class="rate-limit-row">
                    <div class="rate-btn">-</div>
                    <div class="rate-input">↓ 100.0 Mbps</div>
                    <div class="rate-btn">+</div>
                </div>
                <div class="rate-limit-row">
                    <div class="rate-btn">-</div>
                    <div class="rate-input" style="color:#00f0ff;">↑ 10.0 Mbps</div>
                    <div class="rate-btn">+</div>
                </div>
            </div>
        </div>

        <div class="device-card">
            <div class="device-header">
                <span class="ip">192.168.3.1</span>
                <span class="mac">4c:50:77:3d:a3:98</span>
            </div>
            <div class="device-body">
                <div class="toggle-group">
                    <div class="toggle-btn"><div class="toggle-box active"></div> Allow Access</div>
                    <div class="toggle-btn"><div class="toggle-box inactive"></div> Rate Limit</div>
                </div>
                <div class="rate-limit-row">
                    <div class="rate-btn">-</div>
                    <div class="rate-input">↓ 100.0 Mbps</div>
                    <div class="rate-btn">+</div>
                </div>
                <div class="rate-limit-row">
                    <div class="rate-btn">-</div>
                    <div class="rate-input" style="color:#00f0ff;">↑ 10.0 Mbps</div>
                    <div class="rate-btn">+</div>
                </div>
            </div>
        </div>

        <button class="btn" style="width:100%; margin-top:10px; background:#1c3b80; color:#fff; border:1px solid #2a50a0; padding:15px; font-size:1.1rem; border-radius:8px;">Apply All</button>

    </div>

    <%- include('partials/bottom_nav', { activeTab: 'devices' }) %>
</body>
</html>