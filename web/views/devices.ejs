<!DOCTYPE html>
<html lang="en">
  <head>
    <title>HPGTP - Devices</title>
    <%- include('partials/head') %>
    <style>
      .top-status-bar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 24px;
      }

      .device-card {
        background: #ffffff;
        border: 1px solid #e2e8f0;
        border-radius: 12px;
        margin-bottom: 20px;
        box-shadow: 0 1px 2px rgba(0, 0, 0, 0.02);
        overflow: hidden;
      }
      .device-header {
        padding: 12px 20px;
        border-bottom: 1px solid #f1f5f9;
        background: #f8fafc;
        display: flex;
        align-items: baseline;
      }
      .device-header span.ip {
        font-weight: 600;
        color: #0f172a;
        font-size: 1.05rem;
        margin-right: 12px;
        font-family: ui-monospace, monospace;
      }
      .device-header span.mac {
        color: #64748b;
        font-size: 0.85rem;
        font-family: ui-monospace, monospace;
      }

      .device-body {
        padding: 20px;
      }

      .toggle-group {
        display: flex;
        gap: 16px;
        margin-bottom: 20px;
      }
      .toggle-btn {
        display: flex;
        align-items: center;
        background: #f8fafc;
        border: 1px solid #cbd5e1;
        padding: 8px 16px;
        border-radius: 8px;
        color: #334155;
        cursor: pointer;
        font-weight: 500;
        font-size: 0.9rem;
        transition: background 0.2s;
      }
      .toggle-btn:hover {
        background: #f1f5f9;
      }
      .toggle-box {
        width: 18px;
        height: 18px;
        border-radius: 4px;
        margin-right: 10px;
        display: flex;
        justify-content: center;
        align-items: center;
      }
      .toggle-box.active {
        background-color: #4f46e5;
        border: 1px solid #4f46e5;
      }
      .toggle-box.active::after {
        content: "✓";
        color: white;
        font-size: 12px;
        font-weight: bold;
      }
      .toggle-box.inactive {
        border: 1px solid #94a3b8;
        background: #ffffff;
      }

      .rate-limit-row {
        display: flex;
        align-items: center;
        margin-bottom: 12px;
      }
      .rate-btn {
        background: #f1f5f9;
        border: 1px solid #cbd5e1;
        color: #334155;
        width: 36px;
        height: 36px;
        display: flex;
        justify-content: center;
        align-items: center;
        border-radius: 6px;
        cursor: pointer;
        font-size: 1.2rem;
        transition: background 0.2s;
      }
      .rate-btn:hover {
        background: #e2e8f0;
      }
      .rate-input {
        flex: 1;
        background: #ffffff;
        border: 1px solid #cbd5e1;
        color: #0f172a;
        height: 36px;
        display: flex;
        justify-content: center;
        align-items: center;
        margin: 0 12px;
        border-radius: 6px;
        font-family: ui-monospace, monospace;
        font-weight: 500;
      }
      .rate-input.upload {
        color: #4f46e5;
        border-color: #c7d2fe;
        background: #eef2ff;
      }
    </style>
  </head>
  <body>
    <div class="app-container">
      <div class="top-status-bar">
        <div>
          <span class="text-danger font-semibold" style="cursor: pointer"
            >Shutdown</span
          >
          <span
            class="font-semibold"
            style="margin-left: 12px; font-size: 1.1rem"
            >HPGTP</span
          >
        </div>
        <div class="font-mono text-secondary">10.0 10.0 45°C</div>
      </div>

      <div class="page-title" style="margin-bottom: 8px">Device Management</div>
      <div
        class="text-secondary"
        style="font-size: 0.9rem; margin-bottom: 24px"
      >
        Lists all active devices on the subnet. Configure access and rate
        limits, then click Apply All.
      </div>

      <div class="device-card">
        <div class="device-header">
          <span class="ip">192.168.3.14</span>
          <span class="mac">b6:b1:30:dc:93:27</span>
        </div>
        <div class="device-body">
          <div class="toggle-group">
            <div class="toggle-btn">
              <div class="toggle-box active"></div>
              Allow Access
            </div>
            <div class="toggle-btn">
              <div class="toggle-box inactive"></div>
              Rate Limit
            </div>
          </div>
          <div class="rate-limit-row">
            <div class="rate-btn">-</div>
            <div class="rate-input">↓ 100.0 Mbps</div>
            <div class="rate-btn">+</div>
          </div>
          <div class="rate-limit-row">
            <div class="rate-btn">-</div>
            <div class="rate-input upload">↑ 10.0 Mbps</div>
            <div class="rate-btn">+</div>
          </div>
        </div>
      </div>

      <div class="device-card">
        <div class="device-header">
          <span class="ip">192.168.3.1</span>
          <span class="mac">4c:50:77:3d:a3:98</span>
        </div>
        <div class="device-body">
          <div class="toggle-group">
            <div class="toggle-btn">
              <div class="toggle-box active"></div>
              Allow Access
            </div>
            <div class="toggle-btn">
              <div class="toggle-box inactive"></div>
              Rate Limit
            </div>
          </div>
          <div class="rate-limit-row">
            <div class="rate-btn">-</div>
            <div class="rate-input">↓ 100.0 Mbps</div>
            <div class="rate-btn">+</div>
          </div>
          <div class="rate-limit-row">
            <div class="rate-btn">-</div>
            <div class="rate-input upload">↑ 10.0 Mbps</div>
            <div class="rate-btn">+</div>
          </div>
        </div>
      </div>

      <button
        class="btn"
        style="width: 100%; margin-top: 12px; padding: 16px; font-size: 1.05rem"
      >
        Apply All Data Limits
      </button>
    </div>

    <%- include('partials/bottom_nav', { activeTab: 'devices' }) %>
  </body>
</html>
