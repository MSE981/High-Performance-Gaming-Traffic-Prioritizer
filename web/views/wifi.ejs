<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <title>Wi-Fi Settings</title>
    <style>
        body {
            font-family: sans-serif;
            background: #1a1a1a;
            color: white;
            padding: 20px;
            margin: 0;
        }

        h1 {
            text-align: center;
            margin-bottom: 30px;
        }

        .navbar {
            background-color: #2d2d2d;
            overflow: hidden;
            border-radius: 8px;
            margin-bottom: 25px;
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.3);
            display: flex;
            justify-content: center;
        }

        .navbar a {
            display: block;
            color: #ccc;
            text-align: center;
            padding: 14px 20px;
            text-decoration: none;
            font-weight: bold;
            transition: 0.3s;
        }

        .navbar a:hover {
            background-color: #444;
            color: white;
        }

        .navbar a.active {
            background-color: #007bff;
            color: white;
        }

        .container {
            display: flex;
            flex-direction: column;
            align-items: center;
            max-width: 800px;
            margin: 0 auto;
            gap: 20px;
        }

        .panel {
            background: #2d2d2d;
            padding: 30px;
            border-radius: 10px;
            width: 100%;
            box-sizing: border-box;
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.3);
        }

        h2 {
            margin-top: 0;
            border-bottom: 2px solid #444;
            padding-bottom: 10px;
            color: #007bff;
        }

        label {
            display: block;
            margin-top: 20px;
            margin-bottom: 8px;
            color: #ccc;
            font-weight: bold;
        }

        input[type="text"],
        input[type="password"],
        select {
            padding: 12px;
            width: 100%;
            box-sizing: border-box;
            border-radius: 5px;
            border: 1px solid #555;
            background: #222;
            color: white;
            font-size: 16px;
        }

        input:focus,
        select:focus {
            outline: none;
            border-color: #007bff;
        }

        /* Toggle Switch CSS */
        .switch-container {
            display: flex;
            align-items: center;
            margin-top: 20px;
        }

        .switch-label {
            margin-top: 0;
            margin-right: 15px;
        }

        .switch {
            position: relative;
            display: inline-block;
            width: 50px;
            height: 24px;
        }

        .switch input {
            opacity: 0;
            width: 0;
            height: 0;
        }

        .slider {
            position: absolute;
            cursor: pointer;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background-color: #555;
            transition: .4s;
            border-radius: 24px;
        }

        .slider:before {
            position: absolute;
            content: "";
            height: 16px;
            width: 16px;
            left: 4px;
            bottom: 4px;
            background-color: white;
            transition: .4s;
            border-radius: 50%;
        }

        input:checked+.slider {
            background-color: #28a745;
        }

        input:checked+.slider:before {
            transform: translateX(26px);
        }

        button {
            padding: 15px;
            width: 100%;
            background: #007bff;
            color: white;
            border: none;
            cursor: pointer;
            border-radius: 5px;
            font-weight: bold;
            font-size: 18px;
            margin-top: 30px;
            transition: 0.3s;
        }

        button:hover {
            background: #0056b3;
        }

        .hint {
            font-size: 12px;
            color: #888;
            margin-top: 5px;
        }
    </style>
</head>

<body>

    <h1>🚀 Core System Management (BMC)</h1>

    <div class="navbar">
        <a href="/">📊 Dashboard</a>
        <a href="/network">🌐 Network</a>
        <a href="/wifi" class="active">📶 Wi-Fi</a>
        <a href="/qos">🚦 QoS</a>
        <a href="/devices">📱 Devices</a>
        <a href="/logs">📈 Logs</a>
        <a href="/dev">🛠️ Dev</a>
        <a href="/more">⚙️ More</a>
    </div>

    <div class="container">
        <div class="panel">
            <h2>Wireless Configuration</h2>

            <form action="/api/update_wifi" method="POST">

                <label>Wi-Fi Network Name (SSID)</label>
                <input type="text" name="ssid" value="<%= wifiConfig.ssid %>" required>

                <label>Wi-Fi Password</label>
                <input type="password" name="password" value="<%= wifiConfig.password %>" required minlength="8">
                <div class="hint">Must be at least 8 characters long (WPA3-Personal).</div>

                <label>Frequency Band</label>
                <select name="band">
                    <option value="dual" <%=wifiConfig.band==='dual' ? 'selected' : '' %>>Smart Connect (2.4GHz & 5GHz
                        Auto)</option>
                    <option value="5g" <%=wifiConfig.band==='5g' ? 'selected' : '' %>>5GHz Only (High Speed / Low Range)
                    </option>
                    <option value="24g" <%=wifiConfig.band==='24g' ? 'selected' : '' %>>2.4GHz Only (Low Speed / High
                        Range)</option>
                </select>

                <div class="switch-container">
                    <label class="switch-label">Enable Guest Network:</label>
                    <label class="switch">
                        <input type="checkbox" name="guest_network" <%=wifiConfig.guest_network ? 'checked' : '' %>>
                        <span class="slider"></span>
                    </label>
                </div>
                <div class="hint">Isolates connected devices from the main local network.</div>

                <button type="submit">Apply Wi-Fi Settings</button>

            </form>
        </div>
    </div>

</body>

</html>